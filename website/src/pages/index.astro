---
import Layout from '../layouts/Layout.astro';
import LoadingScreen from '../components/LoadingScreen.astro';
import Header from '../components/Header.astro';

const projects = [
  {
    name: 'Windows\nSuper Smooth',
    img1: '/memes/windows-1.jpg',
    img2: '/memes/windows-2.jpg',
    url: 'https://github.com/theyonecodes/Windows-Super-Smooth',
  },
  {
    name: 'CISO\nAuditor',
    img1: '/memes/ciso-1.jpg',
    img2: '/memes/ciso-2.jpg',
    url: 'https://github.com/theyonecodes/CISO-Auditor',
  },
  {
    name: 'Universal\nBrowser Backup',
    img1: '/memes/browser-1.jpg',
    img2: '/memes/browser-2.jpg',
    url: 'https://github.com/theyonecodes/universal-browser-backup',
  },
  {
    name: 'TheyOne\nPM',
    img1: '/memes/pm-1.jpg',
    img2: '/memes/pm-2.jpg',
    url: 'https://github.com/theyonecodes/theyonepm',
  },
  {
    name: 'PkgDrop',
    img1: '/memes/arch-1.jpg',
    img2: '/memes/arch-2.jpg',
    url: 'https://github.com/theyonecodes/pkgdrop',
  },
];
---

<Layout>
  <LoadingScreen />
  <Header />

  <div class="work-page relative z-10 bg-black pointer-events-auto">
    <div class="work-content" id="work-content">
      {projects.map((project, i) => (
        <section class="work-content-item" data-index={i}>
          <div class="work-content-item-inner">
            <div class="work-content-item-title">
              <a href={project.url} target="_blank" rel="noopener">
                <h2 class="work-title">{project.name}</h2>
              </a>
              <div class="work-img-slow-outer primary">
                <img src={project.img1} alt={project.name.replace('\n', ' ')} class="work-img-slow" loading="lazy" />
              </div>
              <div class="work-img-slow-outer secondary">
                <img src={project.img2} alt={project.name.replace('\n', ' ')} class="work-img-slow" loading="lazy" />
              </div>
            </div>
          </div>
        </section>
      ))}
    </div>
  </div>

  <script>
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    gsap.registerPlugin(ScrollTrigger);

    function initWorkPage() {
      const workContent = document.getElementById('work-content');
      const footerContent = document.getElementById('footer-content');
      
      if (!workContent) return;

      const items = workContent.querySelectorAll('.work-content-item');
      const totalItems = items.length;

      // Pin the work content and scroll horizontally
      const scrollTween = gsap.to(workContent, {
        x: -(totalItems - 1) * window.innerWidth,
        ease: 'none',
        scrollTrigger: {
          trigger: '.work-page',
          start: 'top top',
          end: () => `+=${(totalItems - 1) * window.innerWidth}`,
          pin: true,
          scrub: 1,
          invalidateOnRefresh: true,
        },
      });

      // Animate each project
      items.forEach((item, i) => {
        const title = item.querySelector('.work-title');
        const imgPrimary = item.querySelector('.work-img-slow-outer.primary img');
        const imgSecondary = item.querySelector('.work-img-slow-outer.secondary img');

        // Title reveal
        if (title) {
          gsap.to(title, {
            opacity: 1,
            pointerEvents: 'auto',
            ease: 'none',
            scrollTrigger: {
              trigger: item,
              containerAnimation: scrollTween,
              start: 'left 60%',
              end: 'left 40%',
              scrub: true,
            },
          });

          gsap.to(title, {
            opacity: 0,
            pointerEvents: 'none',
            ease: 'none',
            scrollTrigger: {
              trigger: item,
              containerAnimation: scrollTween,
              start: 'right 60%',
              end: 'right 40%',
              scrub: true,
            },
          });
        }

        // Primary image parallax (slow)
        if (imgPrimary) {
          const parent = imgPrimary.parentElement;
          gsap.fromTo(parent,
            { y: 80, opacity: 0 },
            {
              y: 0,
              opacity: 1,
              ease: 'power2.out',
              scrollTrigger: {
                trigger: item,
                containerAnimation: scrollTween,
                start: 'left 70%',
                end: 'left 50%',
                scrub: 1.5,
              },
            }
          );

          gsap.to(parent, {
            y: -40,
            opacity: 0,
            ease: 'power2.in',
            scrollTrigger: {
              trigger: item,
              containerAnimation: scrollTween,
              start: 'right 65%',
              end: 'right 35%',
              scrub: 1.5,
            },
          });

          // Extra slow parallax on scroll
          gsap.to(imgPrimary, {
            y: -30,
            ease: 'none',
            scrollTrigger: {
              trigger: item,
              containerAnimation: scrollTween,
              start: 'left center',
              end: 'right center',
              scrub: 2,
            },
          });
        }

        // Secondary image parallax (slower)
        if (imgSecondary) {
          const parent = imgSecondary.parentElement;
          gsap.fromTo(parent,
            { y: -60, opacity: 0 },
            {
              y: 0,
              opacity: 1,
              ease: 'power2.out',
              scrollTrigger: {
                trigger: item,
                containerAnimation: scrollTween,
                start: 'left 65%',
                end: 'left 45%',
                scrub: 2,
              },
            }
          );

          gsap.to(parent, {
            y: 30,
            opacity: 0,
            ease: 'power2.in',
            scrollTrigger: {
              trigger: item,
              containerAnimation: scrollTween,
              start: 'right 60%',
              end: 'right 30%',
              scrub: 2,
            },
          });

          // Extra slow parallax on scroll
          gsap.to(imgSecondary, {
            y: 20,
            ease: 'none',
            scrollTrigger: {
              trigger: item,
              containerAnimation: scrollTween,
              start: 'left center',
              end: 'right center',
              scrub: 3,
            },
          });
        }
      });

      // Footer visibility
      if (footerContent) {
        gsap.to(footerContent, {
          visibility: 'visible',
          ease: 'none',
          scrollTrigger: {
            trigger: '.work-page',
            start: 'top top',
            end: '+=100',
            scrub: true,
          },
        });
      }
    }

    // Initialize when loading completes
    window.addEventListener('loading-complete', () => {
      document.fonts.ready.then(() => {
        initWorkPage();
      });
    });
  </script>
</Layout>