---
import Layout from '../layouts/Layout.astro';
import Background from '../components/Background.astro';
import CommandPalette from '../components/CommandPalette.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Manifesto from '../components/Manifesto.astro';
import Focus from '../components/Focus.astro';
import Projects from '../components/Projects.astro';
import TechStack from '../components/TechStack.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Background />
  <CommandPalette />
  <Navbar />

  <main class="content-wrapper" id="main">
    <Hero />

    <div class="px-6 lg:px-12"><div class="max-w-7xl mx-auto"><div class="divider"></div></div></div>
    <Manifesto />

    <div class="px-6 lg:px-12"><div class="max-w-7xl mx-auto"><div class="divider"></div></div></div>
    <Focus />

    <div class="px-6 lg:px-12"><div class="max-w-7xl mx-auto"><div class="divider"></div></div></div>
    <Projects />

    <div class="px-6 lg:px-12"><div class="max-w-7xl mx-auto"><div class="divider"></div></div></div>
    <TechStack />

    <div class="px-6 lg:px-12"><div class="max-w-7xl mx-auto"><div class="divider"></div></div></div>
    <Contact />

    <Footer />
  </main>
</Layout>