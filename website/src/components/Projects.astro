---
---

<section id="projects" class="section-padding relative">
  <div class="section-container">
    <div class="max-w-3xl mb-20">
      <div class="reveal">
        <span class="section-label">Projects</span>
      </div>
      <h2 class="section-title reveal delay-1">
        <span class="block">Public Repos</span>
      </h2>
    </div>

    <div id="projects-grid" class="grid md:grid-cols-2 gap-px bg-[var(--color-border)]">
      <div class="col-span-full flex justify-center py-20">
        <div class="flex items-center gap-3 text-xs text-[var(--color-text-3)] font-mono">
          <span class="w-4 h-4 border border-[var(--color-accent)] border-t-transparent rounded-full animate-spin"></span>
          <span>Fetching repositories...</span>
        </div>
      </div>
    </div>

    <div class="mt-16 text-center reveal">
      <a href="https://github.com/theyonecodes" target="_blank" rel="noopener" class="btn">
        <span>View all repositories</span>
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </div>
</section>

<script>
import { initProjects } from '../scripts/projects'
initProjects()
</script>
