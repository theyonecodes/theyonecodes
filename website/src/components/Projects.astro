---
import { Icon } from 'astro-icon/components';
---

<section id="projects" class="section">
  <div class="max-w-7xl mx-auto">
    <div class="flex items-end justify-between mb-16 fade-up">
      <div>
        <span class="section-label">projects.readdir</span>
        <h2 class="section-title">
          <span class="char-reveal">
            <span class="char gradient-text-cyan">P</span><span class="char gradient-text-cyan">r</span><span class="char gradient-text-cyan">o</span><span class="char gradient-text-cyan">j</span><span class="char gradient-text-cyan">e</span><span class="char gradient-text-cyan">c</span><span class="char gradient-text-cyan">t</span><span class="char gradient-text-cyan">s</span>
          </span>
        </h2>
      </div>
    </div>

    <div class="divider mb-16"></div>

    <div id="projects-grid" class="grid md:grid-cols-2 gap-px bg-[var(--color-surface)]">
      <div class="col-span-full flex justify-center py-20">
        <div class="flex items-center gap-3 text-[0.65rem] text-[#555]">
          <span class="w-4 h-4 border border-[var(--color-accent)] border-t-transparent rounded-full animate-spin"></span>
          <span>Fetching repositories...</span>
        </div>
      </div>
    </div>

    <div class="mt-12 text-center fade-up">
      <a href="https://github.com/theyonecodes" target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-[0.7rem] text-[#555] hover:text-[var(--color-accent)] transition-colors">
        <span>View all repositories</span>
        <Icon name="heroicons:arrow-right" class="w-3.5 h-3.5" />
      </a>
    </div>
  </div>
</section>

<script>
const colors: Record<string, string> = {
  Python: '#3572A5', JavaScript: '#F1E05A', TypeScript: '#3178C6', Rust: '#DEA584',
  Bash: '#89e051', Shell: '#89e051', Go: '#00ADD8', 'C++': '#f34b7d', C: '#555',
  HTML: '#e34c26', CSS: '#563d7c',
};

function timeAgo(d: string): string {
  const n = Math.floor((Date.now() - new Date(d).getTime()) / 86400000);
  if (n === 0) return 'today';
  if (n < 7) return n + 'd';
  if (n < 30) return Math.floor(n / 7) + 'w';
  if (n < 365) return Math.floor(n / 30) + 'mo';
  return Math.floor(n / 365) + 'y';
}

(async () => {
  const grid = document.getElementById('projects-grid');
  if (!grid) return;

  try {
    const res = await fetch('https://api.github.com/users/theyonecodes/repos?per_page=12&sort=updated', {
      headers: { 'Accept': 'application/vnd.github.v3+json', 'User-Agent': 'theyonecodes' }
    });
    if (!res.ok) throw new Error('API error');
    const data = await res.json();
    const repos = data
      .filter((x: any) => !x.fork)
      .sort((a: any, b: any) => b.stargazers_count - a.stargazers_count)
      .slice(0, 12);

    if (!repos.length) {
      grid.innerHTML = '<div class="col-span-full text-center py-20 text-[0.7rem] text-[#555]">No public repositories.</div>';
      return;
    }

    grid.innerHTML = repos.map((r: any) => {
      const color = colors[r.language] || '#666';
      const topics = (r.topics || []).slice(0, 2).map((t: string) =>
        '<span class="text-[0.5rem] tracking-[0.1em] text-[#444] px-2.5 py-1 border border-[var(--color-border)]">' + t + '</span>'
      ).join('');
      return '<a href="' + r.html_url + '" target="_blank" rel="noopener" class="card project-card p-8 md:p-10 fade-up group">' +
        '<div class="flex items-start justify-between mb-4">' +
          '<h3 class="text-base font-bold text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors">' + r.name + '</h3>' +
          '<svg class="w-4 h-4 text-[#333] group-hover:text-[var(--color-accent)] transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>' +
        '</div>' +
        '<p class="card-desc mb-6">' + (r.description || '') + '</p>' +
        '<div class="flex items-center justify-between">' +
          '<div class="flex items-center gap-5 text-[0.6rem] text-[#555] font-mono">' +
            '<span class="flex items-center gap-1.5">' +
              '<span class="lang-dot" style="background-color:' + color + '"></span>' +
              (r.language || 'N/A') +
            '</span>' +
            '<span class="flex items-center gap-1">' +
              '<svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34-.46-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.87 1.52 2.34 1.07 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.92 0-1.11.38-2 1.03-2.71-.1-.25-.45-1.29.1-2.64 0 0 .84-.27 2.75 1.02.79-.22 1.65-.33 2.5-.33.85 0 1.71.11 2.5.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.35.2 2.39.1 2.64.65.71 1.03 1.6 1.03 2.71 0 3.82-2.34 4.66-4.57 4.91.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0012 2z"/></svg>' +
              r.stargazers_count +
            '</span>' +
            '<span>' + timeAgo(r.updated_at) + '</span>' +
          '</div>' +
          '<div class="flex gap-1.5">' + topics + '</div>' +
        '</div>' +
      '</a>';
    }).join('');

    requestAnimationFrame(() => {
      document.querySelectorAll('#projects-grid .fade-up').forEach((el) => {
        setTimeout(() => el.classList.add('visible'), 50);
      });
    });
  } catch {
    grid.innerHTML = '<div class="col-span-full text-center py-20 text-[0.7rem] text-[#555]">Could not load repositories.</div>';
  }
})();
</script>