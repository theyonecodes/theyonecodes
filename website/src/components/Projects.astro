---
const featured = [
  {
    name: 'Windows-Super-Smooth',
    pitch: 'The Ultimate Kernel Orchestration Suite for Windows.',
    problem: 'Out-of-the-box Windows runs with bloat and latency.',
    approach: 'Surgical kernel-level tuning — pinned memory, CPU priority, cache purge, DNS optimization.',
    result: '120FPS stability. Zero swap latency. One-click setup.',
    url: 'https://github.com/theyonecodes/Windows-Super-Smooth',
    lang: 'Batchfile',
    langColor: '#89e051',
    tags: ['performance', 'kernel-optimization', 'low-latency'],
  },
  {
    name: 'CISO-Auditor',
    pitch: '100-point Windows security audit — offline, zero deps.',
    problem: 'Small businesses need security audits but cannot afford $10K/year enterprise tools.',
    approach: '100 checks across 8 domains, 15 auto-fixes, dark GUI, multi-format export.',
    result: 'Score out of 100%. Show reports to auditors. One-click hardening.',
    url: 'https://github.com/theyonecodes/CISO-Auditor',
    lang: 'Python',
    langColor: '#3572A5',
    tags: ['security-audit', 'compliance', 'zero-dependency'],
  },
  {
    name: 'universal-browser-backup',
    pitch: 'Backup all browsers in one command.',
    problem: 'Switching machines means losing bookmarks, passwords, history across multiple browsers.',
    approach: 'PowerShell script that extracts and packages data from all major browsers.',
    result: 'One portable backup file. Restore anywhere. Zero config.',
    url: 'https://github.com/theyonecodes/universal-browser-backup',
    lang: 'PowerShell',
    langColor: '#012456',
    tags: ['backup', 'browsers', 'automation'],
  },
]
---

<section id="projects" class="section-padding relative">
  <div class="section-container">
    <div class="max-w-3xl mb-20 md:mb-28">
      <div class="gsap-reveal">
        <span class="section-label">Projects</span>
      </div>
      <h2 class="section-title gsap-reveal">
        <span class="block">Featured Work</span>
      </h2>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-px bg-[var(--color-border)] mb-24">
      {featured.map((p, i) => {
        const delayStyle = "transition-delay: " + (i * 0.12) + "s"
        const index = "0" + (i + 1)
        const displayTags = p.tags.slice(0, 2)
        return (
          <a href={p.url} target="_blank" rel="noopener" class="feature-card p-8 md:p-10 group gsap-reveal" style={delayStyle} data-tilt>
            <div class="relative z-10">
              <div class="flex items-center justify-between mb-6">
                <span class="text-mono text-[10px] text-[var(--color-text-3)] tracking-widest uppercase">{index}</span>
                <svg class="w-4 h-4 text-[var(--color-text-3)] group-hover:text-[var(--color-accent)] transition-all duration-300 group-hover:translate-x-1 group-hover:-translate-y-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
              </div>
              <h3 class="text-xl md:text-2xl font-display font-800 mb-2 group-hover:text-[var(--color-accent)] transition-colors duration-300">{p.name}</h3>
              <p class="text-mono text-[11px] text-[var(--color-accent)] mb-6 italic">{p.pitch}</p>
              <div class="space-y-3 mb-8">
                <div class="flex gap-3">
                  <span class="text-mono text-[10px] text-[var(--color-text-3)] shrink-0 mt-0.5 tracking-wider">PROBLEM</span>
                  <p class="text-body text-xs leading-relaxed">{p.problem}</p>
                </div>
                <div class="flex gap-3">
                  <span class="text-mono text-[10px] text-[var(--color-accent)] shrink-0 mt-0.5 tracking-wider">APPROACH</span>
                  <p class="text-body text-xs leading-relaxed">{p.approach}</p>
                </div>
                <div class="flex gap-3">
                  <span class="text-mono text-[10px] text-[var(--color-text-3)] shrink-0 mt-0.5 tracking-wider">RESULT</span>
                  <p class="text-body text-xs leading-relaxed">{p.result}</p>
                </div>
              </div>
              <div class="flex items-center justify-between">
                <div class="flex gap-1.5">
                  {displayTags.map((t) => (
                    <span class="tag text-[10px]">{t}</span>
                  ))}
                </div>
                <div class="flex items-center gap-3 text-[10px] text-[var(--color-text-3)] text-mono">
                  <span class="flex items-center gap-1.5">
                    <span class="w-1.5 h-1.5 rounded-full" style={"background-color:" + p.langColor}></span>
                    {p.lang}
                  </span>
                </div>
              </div>
            </div>
          </a>
        )
      })}
    </div>

    <div class="max-w-3xl mb-12">
      <div class="gsap-reveal">
        <span class="section-label all-repos-label">All Repos</span>
      </div>
      <h2 class="section-title gsap-reveal text-[clamp(1.5rem,4vw,3rem)] all-repos-title">
        <span class="block">Public Repos</span>
      </h2>
    </div>

    <div id="projects-grid" class="grid md:grid-cols-2 gap-px bg-[var(--color-border)]">
      <div class="col-span-full flex justify-center py-20">
        <div class="flex items-center gap-3 text-xs text-[var(--color-text-3)] font-mono">
          <span class="w-4 h-4 border border-[var(--color-accent)] border-t-transparent rounded-full animate-spin"></span>
          <span>Fetching repositories...</span>
        </div>
      </div>
    </div>

    <div class="mt-16 text-center gsap-reveal">
      <a href="https://github.com/theyonecodes" target="_blank" rel="noopener" class="btn magnetic">
        <span>View all repositories</span>
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </div>
  </div>
</section>

<script>
import { initProjects } from '../scripts/projects'
initProjects()
</script>
