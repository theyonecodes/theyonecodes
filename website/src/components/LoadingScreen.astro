---

<div id="loading-screen">
  <div class="ascii-text-container">
    <canvas id="ascii-canvas"></canvas>
  </div>
</div>

<script>
  const canvas = document.getElementById('ascii-canvas') as HTMLCanvasElement
  const ctx = canvas?.getContext('2d')
  const loadingScreen = document.getElementById('loading-screen')

  if (canvas && ctx) {
    const resize = () => {
      canvas.width = window.innerWidth * window.devicePixelRatio
      canvas.height = window.innerHeight * window.devicePixelRatio
      canvas.style.width = window.innerWidth + 'px'
      canvas.style.height = window.innerHeight + 'px'
      ctx?.scale(window.devicePixelRatio, window.devicePixelRatio)
    }
    resize()
    window.addEventListener('resize', resize)

    const asciiChars = '█▓▒░@B%8&WM#*oahkbdpqwmZO0QLCJUYXzcvunxrjft/\\|()1{}[]?-_+~<>i!lI;:,"^`\'. '
    const text = 'theyone'
    let time = 0
    let loaded = false

    function draw() {
      if (!ctx) return
      
      ctx.fillStyle = '#000'
      ctx.fillRect(0, 0, canvas.width, canvas.height)
      
      ctx.fillStyle = '#fff'
      ctx.font = '10px "IBM Plex Mono", monospace'
      ctx.textAlign = 'center'
      ctx.textBaseline = 'middle'

      const centerX = window.innerWidth / 2
      const centerY = window.innerHeight / 2
      const fontSize = Math.min(window.innerWidth, window.innerHeight) * 0.15

      // Draw ASCII art sphere/shape
      const radius = Math.min(window.innerWidth, window.innerHeight) * 0.2
      const chars: string[] = []
      
      for (let y = -radius; y <= radius; y += 8) {
        let line = ''
        for (let x = -radius; x <= radius; x += 4) {
          const dist = Math.sqrt(x * x + y * y)
          if (dist <= radius) {
            const noise = Math.sin((x + time * 20) * 0.05) * Math.cos((y + time * 20) * 0.05)
            const charIndex = Math.floor((noise + 1) / 2 * (asciiChars.length - 1))
            line += asciiChars[Math.max(0, Math.min(asciiChars.length - 1, charIndex))]
          } else {
            line += ' '
          }
        }
        chars.push(line)
      }

      const asciiText = chars.join('\n')
      const lines = asciiText.split('\n')
      
      ctx.font = `${Math.max(8, fontSize / 20)}px "IBM Plex Mono", monospace`
      lines.forEach((line, i) => {
        ctx.fillText(line, centerX, centerY - (lines.length * 4) + i * 8)
      })

      time += 0.02

      if (!loaded && time > 100) {
        loaded = true
        loadingScreen?.style.setProperty('opacity', '0')
        loadingScreen?.style.setProperty('pointer-events', 'none')
        setTimeout(() => {
          window.dispatchEvent(new Event('loading-complete'))
        }, 600)
      } else {
        requestAnimationFrame(draw)
      }
    }

    draw()
  } else {
    setTimeout(() => {
      loadingScreen?.style.setProperty('opacity', '0')
      loadingScreen?.style.setProperty('pointer-events', 'none')
      window.dispatchEvent(new Event('loading-complete'))
    }, 2000)
  }
</script>