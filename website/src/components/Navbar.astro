---
---

<nav class="navbar fixed top-0 left-0 right-0 z-50" id="navbar">
  <div class="section-container flex items-center justify-between h-16 md:h-20">
    <a href="/" class="text-sm font-semibold tracking-tight text-white hover:text-[var(--color-accent)] transition-colors duration-300">
      TheyOne
    </a>
    <div class="hidden md:flex items-center gap-8">
      {['philosophy', 'focus', 'projects', 'contact'].map((id) => (
        <a
          href={`#${id}`}
          class="nav-link text-[10px] tracking-[0.2em] uppercase text-white/40 hover:text-white transition-colors duration-300"
        >
          {id}
        </a>
      ))}
    </div>
  </div>
</nav>

<div class="scroll-indicator fixed right-6 top-1/2 -translate-y-1/2 z-50 hidden lg:flex flex-col items-center gap-2">
  {['hero', 'philosophy', 'focus', 'projects', 'contact'].map((id) => (
    <a href={`#${id}`} class="scroll-dot w-[1px] h-6 bg-white/10 hover:bg-[var(--color-accent)] transition-all duration-300" data-section={id}></a>
  ))}
</div>

<script>
import { prefersReducedMotion } from '../scripts/utils'

if (!prefersReducedMotion()) {
  const navbar = document.getElementById('navbar') as HTMLElement
  if (navbar) {
    let lastScroll = 0
    let ticking = false

    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          const current = window.scrollY
          if (current > lastScroll && current > 100) {
            navbar.style.transform = 'translateY(-100%)'
          } else {
            navbar.style.transform = 'translateY(0)'
          }
          lastScroll = current
          ticking = false
        })
        ticking = true
      }
    })
  }

  const dots = document.querySelectorAll('.scroll-dot')
  const sections = ['hero', 'philosophy', 'focus', 'projects', 'contact']

  sections.forEach((id) => {
    const el = document.getElementById(id)
    if (!el) return
    new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            updateDots(id)
          }
        })
      },
      { rootMargin: '-50% 0px -50% 0px' }
    ).observe(el)
  })

  function updateDots(active: string) {
    dots.forEach((dot) => {
      const el = dot as HTMLElement
      if (el.dataset.section === active) {
        el.style.background = 'var(--color-accent)'
        el.style.height = '2rem'
      } else {
        el.style.background = 'rgba(255,255,255,0.1)'
        el.style.height = '1.5rem'
      }
    })
  }
}
</script>

<style>
  .navbar {
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    background: rgba(10, 10, 10, 0.6);
  }
</style>
