---
const items = [
  { href: '#manifesto', label: 'Manifesto' },
  { href: '#focus', label: 'Focus' },
  { href: '#projects', label: 'Projects' },
  { href: '#stack', label: 'Stack' },
  { href: '/blog', label: 'Writing' },
  { href: 'https://github.com/theyonecodes', label: 'GitHub' },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 glass border-b border-[rgba(255,255,255,0.03)]">
  <div class="max-w-7xl mx-auto px-6 lg:px-12 h-16 flex items-center justify-between">
    <a href="/" class="text-[0.6rem] font-semibold tracking-[0.4em] text-[#555] hover:text-[var(--color-accent)] transition-colors duration-300 uppercase">
      TheyOne
    </a>

    <div class="hidden md:flex items-center gap-10">
      {items.map(item => (
        <a
          href={item.href}
          class="text-[0.65rem] font-medium tracking-[0.05em] text-[#555] hover:text-[var(--color-accent)] transition-colors duration-200 uppercase"
        >
          {item.label}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-4">
      <button
        class="hidden md:flex items-center gap-2 px-3 py-1.5 text-[0.55rem] text-[#444] bg-[var(--color-surface)] border border-[var(--color-border)] rounded hover:border-[#333] transition-colors"
        onclick="document.getElementById('palette')?.classList.toggle('active'); document.getElementById('palette-input')?.focus()"
      >
        Search<kbd class="px-1 py-0.5 text-[0.5rem] font-mono bg-[#111] rounded">⌘K</kbd>
      </button>
      <div class="flex items-center gap-2">
        <div class="status-dot"></div>
        <span class="text-[0.5rem] tracking-[0.25em] text-[#333] uppercase hidden sm:block">Operational</span>
      </div>
    </div>
  </div>
</nav>

<script>
  const palette = document.getElementById('palette');
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      palette?.classList.toggle('active');
      if (palette?.classList.contains('active')) {
        setTimeout(() => document.getElementById('palette-input')?.focus(), 50);
      }
    }
  });
</script>