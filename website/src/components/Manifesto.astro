---
const principles = [
  {
    id: '01',
    title: 'Zero Waste',
    desc: 'Every line of code earns its place. No bloat, no borrowed abstractions. Dependencies are liabilities.',
  },
  {
    id: '02',
    title: 'Maximum Speed',
    desc: 'Startup time is a feature. Latency is a bug. Performance is non-negotiable. The best code runs instantly.',
  },
  {
    id: '03',
    title: 'Digital Sovereignty',
    desc: 'Tools run on my hardware. No telemetry, no accounts, no cloud dependency. Your data stays yours.',
  },
  {
    id: '04',
    title: 'Autonomous Execution',
    desc: 'Once built, the system runs. No prompts, no confirmations. Build it once, let it work forever.',
  },
]
---

<section id="philosophy" class="section-padding relative grid-bg">
  <div class="section-container">
    <div class="max-w-3xl mb-20 md:mb-28">
      <div class="gsap-reveal">
        <span class="section-label">Philosophy</span>
      </div>
      <h2 class="section-title gsap-reveal">
        <span class="block">The Principles</span>
      </h2>
    </div>

    <div class="grid md:grid-cols-2 gap-px bg-[var(--color-border)]">
      {principles.map((p, i) => {
        const delayStyle = "transition-delay: " + (i * 0.1) + "s"
        return (
          <div class="card p-8 md:p-12 lg:p-16 group relative overflow-hidden gsap-reveal" style={delayStyle}>
            <span class="manifesto-num absolute top-4 right-6 text-[6rem] md:text-[8rem] font-display font-800 text-[var(--color-border)] opacity-40 leading-none select-none pointer-events-none transition-all duration-700 group-hover:opacity-60 group-hover:scale-110">
              {p.id}
            </span>
            <div class="relative z-10">
              <div class="flex items-center gap-4 mb-6">
                <span class="text-mono text-xs text-[var(--color-accent)]">{p.id}</span>
                <div class="w-8 h-[1px] bg-[var(--color-border)] group-hover:bg-[var(--color-accent)] group-hover:w-16 transition-all duration-500"></div>
              </div>
              <h3 class="text-2xl md:text-3xl lg:text-4xl font-display font-800 mb-4 group-hover:text-[var(--color-accent)] transition-colors duration-300">{p.title}</h3>
              <p class="text-body text-sm leading-relaxed max-w-sm">{p.desc}</p>
            </div>
          </div>
        )
      })}
    </div>
  </div>
</section>
