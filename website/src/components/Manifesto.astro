<section id="manifesto" class="section-padding relative">
  <div class="section-container">
    <div class="max-w-3xl mb-16">
      <span class="section-label">Manifesto</span>
      <h2 class="section-title">
        <span class="block">The Principles</span>
      </h2>
    </div>

    <div class="grid md:grid-cols-2 gap-px bg-[var(--color-border)]">
      {[
        { id: '01', title: 'Zero Waste', desc: 'Every line of code earns its place. No bloat, no borrowed abstractions. Dependencies are liabilities.' },
        { id: '02', title: 'Maximum Speed', desc: 'Startup time is a feature. Latency is a bug. Performance is non-negotiable. Lean code is fast code.' },
        { id: '03', title: 'Digital Sovereignty', desc: 'Tools run on my hardware. On my terms. No telemetry, no accounts, no cloud dependency.' },
        { id: '04', title: 'Autonomous Execution', desc: 'Once built, the system runs. No prompts, no confirmations, no hand-holding. Autonomous by design.' },
      ].map(p => (
        <div class="card p-8 md:p-12 principle-card" data-index={p.id}>
          <div class="flex items-center gap-4 mb-5">
            <span class="text-mono text-xs text-[var(--color-accent)]">{p.id}</span>
            <h3 class="text-xl font-semibold text-display">{p.title}</h3>
          </div>
          <p class="text-body text-sm">{p.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
import { createSectionAnimation } from '../scripts/gsap-setup'

document.querySelectorAll('.principle-card').forEach((el, i) => {
  gsap.fromTo(el, {
    opacity: 0,
    y: 60,
  }, {
    opacity: 1,
    y: 0,
    duration: 0.8,
    delay: i * 0.1,
    ease: 'power3.out',
    scrollTrigger: {
      trigger: el,
      start: 'top 85%',
      end: 'top 35%',
      toggleActions: 'play none none reverse',
    },
  })
})
</script>
