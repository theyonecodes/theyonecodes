---
---

<section id="philosophy" class="section-padding relative">
  <div class="section-container">
    <div class="max-w-3xl mb-20">
      <div class="reveal">
        <span class="section-label">Philosophy</span>
      </div>
      <h2 class="section-title reveal delay-1">
        <span class="block">The Principles</span>
      </h2>
    </div>

    <div class="grid md:grid-cols-2 gap-px bg-[var(--color-border)]">
      {[
        {
          id: '01',
          title: 'Zero Waste',
          desc: 'Every line of code earns its place. No bloat, no borrowed abstractions. Dependencies are liabilities — each one is a potential point of failure.',
          accent: false,
        },
        {
          id: '02',
          title: 'Maximum Speed',
          desc: 'Startup time is a feature. Latency is a bug. Performance is non-negotiable. The best code is the code that runs instantly.',
          accent: true,
        },
        {
          id: '03',
          title: 'Digital Sovereignty',
          desc: 'Tools run on my hardware. On my terms. No telemetry, no accounts, no cloud dependency. Your data stays yours.',
          accent: false,
        },
        {
          id: '04',
          title: 'Autonomous Execution',
          desc: 'Once built, the system runs. No prompts, no confirmations, no hand-holding. Build it once, let it work forever.',
          accent: true,
        },
      ].map((p, i) => (
        <div class={`card p-8 md:p-12 group reveal ${i % 2 === 0 ? 'delay-' + (i + 1) : 'delay-' + (i + 1)}`}>
          <div class="flex items-center gap-4 mb-6">
            <span class="text-mono text-xs text-[var(--color-accent)]">{p.id}</span>
            <div class="w-8 h-[1px] bg-[var(--color-border)] group-hover:bg-[var(--color-accent)] transition-colors duration-500"></div>
          </div>
          <h3 class="text-xl md:text-2xl font-semibold text-display mb-4">{p.title}</h3>
          <p class="text-body text-sm leading-relaxed">{p.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
