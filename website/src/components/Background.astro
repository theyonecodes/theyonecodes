---
---

<canvas id="bg-canvas"></canvas>

<script>
(function () {
  const canvas = document.getElementById('bg-canvas');
  if (!canvas) return;

  const gl = canvas.getContext('webgl', { alpha: true, antialias: false, powerPreference: 'high-performance' });
  if (!gl) { canvas.style.display = 'none'; return; }

  const resize = () => {
    const dpr = Math.min(window.devicePixelRatio, 2);
    const w = window.innerWidth;
    const h = window.innerHeight;
    canvas.width = w * dpr;
    canvas.height = h * dpr;
    canvas.style.width = w + 'px';
    canvas.style.height = h + 'px';
    gl.viewport(0, 0, canvas.width, canvas.height);
  };
  resize();
  window.addEventListener('resize', resize);

  const vertexSrc = `
    attribute vec2 position;
    void main() {
      gl_Position = vec4(position, 0.0, 1.0);
    }
  `;

  const fragmentSrc = `
    precision highp float;
    uniform vec2 u_res;
    uniform float u_time;

    // Raymarching grid
    float sdBox(vec3 p, vec3 b) {
      vec3 q = abs(p) - b;
      return length(max(q, 0.0)) + min(max(q.x, max(q.y, q.z)), 0.0);
    }

    void main() {
      vec2 uv = (gl_FragCoord.xy - 0.5 * u_res) / min(u_res.x, u_res.y);
      vec3 ro = vec3(0.0, 1.0, -3.0);
      vec3 rd = normalize(vec3(uv.x * 1.5, uv.y * 1.0, 0.5));

      float t = 0.0;
      vec3 col = vec3(0.0);
      bool hit = false;

      // Floor grid
      for (int i = 0; i < 80; i++) {
        vec3 p = ro + rd * t;
        float d = p.y;  // distance to floor
        if (d < 0.01 && d > -0.01) {
          hit = true;
          // Grid lines
          vec3 gp = p;
          float gridX = fract(gp.x * 0.5 + 0.5);
          float gridZ = fract(gp.z * 0.5 + 0.5);
          float lineX = 1.0 - smoothstep(0.0, 0.02, min(gridX, 1.0 - gridX));
          float lineZ = 1.0 - smoothstep(0.0, 0.02, min(gridZ, 1.0 - gridZ));
          float grid = max(lineX, lineZ) * 0.6;

          // Distance fade
          float fade = 1.0 / (1.0 + t * t * 0.1);
          fade = max(0.0, fade - 0.1);

          // Pulse wave
          float wave = sin(gp.x * 0.5 + u_time * 0.3) * 0.5 + 0.5;
          float wave2 = sin(gp.z * 0.5 + u_time * 0.2 + 1.0) * 0.5 + 0.5;
          float pulse = (wave + wave2) * 0.5;

          // Color: green with cyan accent
          vec3 gridColor = mix(vec3(0.0, 0.8, 0.4), vec3(0.1, 0.9, 0.6), pulse);
          gridColor = mix(gridColor, vec3(0.1, 0.6, 0.9), sin(u_time * 0.1 + gp.x) * 0.3 + 0.3);

          float alpha = grid * fade * (0.4 + pulse * 0.3);
          col += gridColor * alpha;
          break;
        }
        t += d * 1.5;
        if (t > 50.0) break;
      }

      // Vertical lines (tall pillars)
      for (int j = -6; j <= 6; j++) {
        float x = float(j) * 2.0;
        vec3 p = ro + rd * t;
        float dist = abs(p.x - x);
        float line = 1.0 - smoothstep(0.0, 0.02, dist);
        float fade = 1.0 / (1.0 + p.z * p.z * 0.05);
        fade = max(0.0, fade - 0.1);
        float pulse = sin(u_time * 0.5 + float(j)) * 0.5 + 0.5;
        col += vec3(0.0, 0.6 + pulse * 0.3, 0.3) * line * fade * 0.3;
      }

      // Horizon glow
      float horizonGlow = exp(-abs(uv.y) * 8.0) * 0.15;
      col += vec3(0.0, 1.0, 0.4) * horizonGlow;

      // Vignette
      float vignette = 1.0 - length(uv * 1.2);
      col *= vignette;

      gl_FragColor = vec4(col * 0.8, 1.0);
    }
  `;

  function compileShader(src, type) {
    const shader = gl.createShader(type);
    gl.shaderSource(shader, src);
    gl.compileShader(shader);
    if (!gl.getShaderParameter(shader, gl.COMPILE_STATUS)) {
      console.error(gl.getShaderInfoLog(shader));
      gl.deleteShader(shader);
      return null;
    }
    return shader;
  }

  const vs = compileShader(vertexSrc, gl.VERTEX_SHADER);
  const fs = compileShader(fragmentSrc, gl.FRAGMENT_SHADER);
  const prog = gl.createProgram();
  gl.attachShader(prog, vs);
  gl.attachShader(prog, fs);
  gl.linkProgram(prog);
  gl.useProgram(prog);

  const quad = new Float32Array([-1, -1, 1, -1, -1, 1, 1, 1]);
  const buf = gl.createBuffer();
  gl.bindBuffer(gl.ARRAY_BUFFER, buf);
  gl.bufferData(gl.ARRAY_BUFFER, quad, gl.STATIC_DRAW);

  const posAttr = gl.getAttribLocation(prog, 'position');
  gl.enableVertexAttribArray(posAttr);
  gl.vertexAttribPointer(posAttr, 2, gl.FLOAT, false, 0, 0);

  const resLoc = gl.getUniformLocation(prog, 'u_res');
  const timeLoc = gl.getUniformLocation(prog, 'u_time');

  let start = performance.now();
  let visible = true;

  document.addEventListener('visibilitychange', () => {
    visible = !document.hidden;
    if (visible) start = performance.now();
  });

  let anim;
  function render() {
    if (visible) {
      const elapsed = (performance.now() - start) / 1000;
      gl.uniform2f(resLoc, canvas.width, canvas.height);
      gl.uniform1f(timeLoc, elapsed);
      gl.drawArrays(gl.TRIANGLE_STRIP, 0, 4);
      anim = requestAnimationFrame(render);
    }
  }
  render();
})();
</script>