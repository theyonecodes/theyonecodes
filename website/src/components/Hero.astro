<section id="hero" class="relative min-h-screen flex items-center section-padding">
  <div class="section-container w-full relative z-10">
    <div class="max-w-6xl">
      <p class="text-mono text-xs text-[var(--color-accent)] tracking-[0.2em] uppercase mb-6" id="hero-label">
        TheyOne Codes
      </p>
      <h1 class="text-display text-[clamp(3.5rem,12vw,10rem)] leading-[0.85] tracking-[-0.04em]" id="hero-title">
        <span class="block">TheyOne</span>
        <span class="block text-[var(--color-text-2)]">Codes</span>
      </h1>
      <p class="text-body text-base md:text-lg max-w-xl mt-8 mb-10" id="hero-desc">
        Building autonomous execution systems. No vendor lock-in, no third-party dependencies, no compromises.
      </p>
      <div class="flex items-center gap-4" id="hero-actions">
        <a href="https://github.com/theyonecodes" target="_blank" rel="noopener" class="btn btn-primary">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          <span>GitHub</span>
        </a>
        <a href="#manifesto" class="btn">
          <span>Explore</span>
        </a>
      </div>
    </div>
  </div>

  <div class="absolute bottom-12 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2" id="scroll-hint">
    <span class="text-mono text-[10px] text-[var(--color-text-3)] tracking-widest uppercase">Scroll</span>
    <div class="w-[1px] h-10 bg-gradient-to-b from-[var(--color-text-3)] to-transparent"></div>
  </div>
</section>

<script>
import { prefersReducedMotion } from '../scripts/utils'

if (!prefersReducedMotion()) {
  const label = document.getElementById('hero-label')
  const blocks = document.querySelectorAll('#hero-title .block')
  const desc = document.getElementById('hero-desc')
  const actions = document.getElementById('hero-actions')
  const scrollHint = document.getElementById('scroll-hint')

  const elements = [label, ...blocks, desc, actions, scrollHint].filter(Boolean)

  elements.forEach((el, i) => {
    (el as HTMLElement).style.opacity = '0'
    ;(el as HTMLElement).style.transform = 'translateY(30px)'
  })

  requestAnimationFrame(() => {
    elements.forEach((el, i) => {
      setTimeout(() => {
        if (el) {
          (el as HTMLElement).style.transition = 'opacity 0.6s ease, transform 0.6s ease'
          ;(el as HTMLElement).style.opacity = '1'
          ;(el as HTMLElement).style.transform = 'translateY(0)'
        }
      }, i * 120)
    })
  })
}
</script>

<style>
  #hero {
    pointer-events: auto;
  }
</style>
