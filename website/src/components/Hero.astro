---
import { Icon } from 'astro-icon/components';
---

<section class="min-h-screen flex items-center px-6 lg:px-12 pt-32">
  <div class="max-w-7xl mx-auto w-full">
    <div class="flex items-center gap-2 mb-8 fade-up">
      <span class="w-6 h-[1px] bg-[var(--color-accent)] opacity-50"></span>
      <span class="text-[0.6rem] font-semibold tracking-[0.3em] text-[var(--color-text-3)] uppercase">// theyone_codes.sys</span>
    </div>

    <h1 class="text-[clamp(3rem,15vw,10rem)] font-black leading-[0.85] mb-8">
      <span class="char-reveal">
        <span class="char gradient-text" style="display:inline-block">T</span>
        <span class="char gradient-text" style="display:inline-block">H</span>
        <span class="char gradient-text" style="display:inline-block">E</span>
        <span class="char gradient-text" style="display:inline-block">Y</span>
        <span class="char gradient-text" style="display:inline-block">O</span>
        <span class="char gradient-text" style="display:inline-block">N</span>
        <span class="char gradient-text" style="display:inline-block">E</span>
      </span><br>
      <span class="char-reveal">
        <span class="char text-[var(--color-text-3)]" style="display:inline-block">C</span>
        <span class="char text-[var(--color-text-3)]" style="display:inline-block">O</span>
        <span class="char text-[var(--color-text-3)]" style="display:inline-block">D</span>
        <span class="char text-[var(--color-text-3)]" style="display:inline-block">E</span>
        <span class="char text-[var(--color-text-3)]" style="display:inline-block">S</span>
      </span>
    </h1>

    <div class="flex items-center gap-2 text-sm font-medium text-[var(--color-text-3)] mb-12 fade-up">
      <span class="text-[var(--color-accent)]">$</span>
      <span>zero_waste</span>
      <span class="text-[#333]">.</span>
      <span>maximum_speed</span>
      <span class="text-[#333]">.</span>
      <span class="text-[var(--color-cyan)]">autonomy</span>
      <span class="text-[var(--color-accent)]">()</span>
      <span class="animate-pulse text-[var(--color-accent)]">_</span>
    </div>

    <p class="text-sm text-[var(--color-text-3)] max-w-xl leading-relaxed mb-16 fade-up">
      Building autonomous execution systems. Alone. Since day one.<br>
      <span class="text-[#666]">No vendor lock-in.</span>
      <span class="text-[#555]">No third-party dependencies.</span>
      <span class="text-[var(--color-accent)]">No compromises.</span>
    </p>

    <div class="flex items-center gap-6 flex-wrap fade-up">
      <a href="https://github.com/theyonecodes" target="_blank" rel="noopener" class="btn btn-primary neon-glow">
        <Icon name="simple-icons:github" class="w-4 h-4" />
        <span>View GitHub</span>
      </a>
      <a href="#manifesto" class="btn btn-secondary">
        <span>Read Manifesto</span>
      </a>
    </div>

    <div class="mt-32 grid grid-cols-2 md:grid-cols-4 gap-8 fade-up">
      <div><div class="stat-number glitch" data-text="42">42</div><div class="stat-label mt-2">repos</div></div>
      <div><div class="stat-number">0</div><div class="stat-label mt-2">third-party deps</div></div>
      <div><div class="stat-number">100</div><div class="stat-label mt-2">autonomy</div></div>
      <div><div class="stat-number">∞</div><div class="stat-label mt-2">zero waste</div></div>
    </div>
  </div>
</section>