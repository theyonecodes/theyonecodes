---
import { prefersReducedMotion } from '../scripts/utils'
---

<section id="hero" class="relative min-h-screen flex items-center overflow-hidden">
  <div class="absolute inset-0 z-0" id="hero-gradient"></div>

  <div class="section-container w-full relative z-10">
    <div class="max-w-5xl">
      <div class="reveal delay-0">
        <p class="text-mono text-xs text-[var(--color-accent)] tracking-[0.25em] uppercase mb-8">
          <span class="inline-block w-8 h-[1px] bg-[var(--color-accent)] mr-3 align-middle"></span>
          TheyOne Codes
        </p>
      </div>

      <h1 class="text-display text-[clamp(3rem,11vw,9rem)] leading-[0.88] tracking-[-0.04em] mb-8">
        <span class="block reveal delay-1">Building</span>
        <span class="block reveal delay-2 text-[var(--color-text-2)]">autonomous</span>
        <span class="block reveal delay-3">systems<span class="text-[var(--color-accent)]">.</span></span>
      </h1>

      <div class="reveal delay-4">
        <p class="text-body text-base md:text-lg max-w-xl mb-12 leading-relaxed">
          No vendor lock-in. No third-party dependencies. No compromises.
          Every tool runs on my hardware, on my terms.
        </p>
      </div>

      <div class="flex flex-wrap items-center gap-4 reveal delay-5">
        <a href="https://github.com/theyonecodes" target="_blank" rel="noopener" class="btn btn-primary">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          <span>GitHub</span>
        </a>
        <a href="#philosophy" class="btn">
          <span>Read Philosophy</span>
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
        </a>
      </div>
    </div>
  </div>

  <div class="absolute bottom-12 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-3 reveal delay-6">
    <span class="text-mono text-[9px] text-[var(--color-text-3)] tracking-[0.3em] uppercase">Scroll</span>
    <div class="w-[1px] h-12 bg-gradient-to-b from-[var(--color-text-3)] to-transparent animate-pulse"></div>
  </div>
</section>

<style>
  #hero-gradient {
    background:
      radial-gradient(ellipse 80% 60% at 20% 50%, rgba(34, 211, 238, 0.04) 0%, transparent 60%),
      radial-gradient(ellipse 60% 50% at 80% 30%, rgba(124, 92, 252, 0.03) 0%, transparent 60%),
      radial-gradient(ellipse 50% 40% at 50% 80%, rgba(245, 202, 64, 0.02) 0%, transparent 60%);
    pointer-events: none;
  }
</style>
