---
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <div class="absolute inset-0 grid-bg animate-grid opacity-30" />

  <div class="absolute inset-0 bg-gradient-to-b from-accent/5 via-transparent to-transparent" />

  <div class="relative z-10 text-center px-6">
    <div class="mb-6 inline-flex items-center gap-2 px-4 py-2 rounded-full border border-border bg-surface/50 backdrop-blur-sm">
      <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse" />
      <span class="text-sm text-muted">Operational — Building autonomy</span>
    </div>

    <h1 class="text-6xl md:text-8xl font-black tracking-tight mb-6 text-gradient animate-gradient">
      TheyOne Codes
    </h1>

    <div class="flex items-center justify-center gap-4 text-lg md:text-xl font-mono text-muted mb-12">
      <span class="text-accent">Zero waste.</span>
      <span class="text-purple-400">Maximum speed.</span>
    </div>

    <p class="text-lg text-muted max-w-xl mx-auto mb-12 leading-relaxed">
      Engineering autonomous execution systems.<br />
      Refusing third-party dependencies since day one.
    </p>

    <div class="flex flex-wrap items-center justify-center gap-4">
      <a
        href="#principles"
        class="px-8 py-4 bg-accent text-bg font-semibold rounded-lg hover:bg-accent-dim transition-all duration-200 hover:translate-y-[-2px] glow"
      >
        Explore the work
      </a>
      <a
        href="https://github.com/theyonecodes"
        class="px-8 py-4 border border-border text-text font-semibold rounded-lg hover:border-muted transition-all duration-200"
      >
        View GitHub
      </a>
    </div>
  </div>

  <div class="absolute bottom-12 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>

<style>
  .grid-bg {
    background-image:
      linear-gradient(rgba(34, 211, 238, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(34, 211, 238, 0.03) 1px, transparent 1px);
    background-size: 80px 80px;
  }
</style>