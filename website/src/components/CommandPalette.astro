---
import { Icon } from 'astro-icon/components';

const commands = [
  { name: 'Home', href: '#' },
  { name: 'Manifesto', href: '#manifesto' },
  { name: 'Focus', href: '#focus' },
  { name: 'Projects', href: '#projects' },
  { name: 'Tech Stack', href: '#stack' },
  { name: 'Writing', href: '/blog' },
  { name: 'GitHub', href: 'https://github.com/theyonecodes' },
];
---

<div id="palette">
  <div class="backdrop" onclick="closePalette()"></div>
  <div class="panel">
    <div class="inner">
      <div class="search-area">
        <Icon name="heroicons:magnifying-glass" class="w-4 h-4 text-[#555]" />
        <input id="palette-input" type="text" placeholder="Type a command or search..." autocomplete="off" />
        <kbd class="hidden sm:inline-flex px-1.5 py-0.5 text-[0.5rem] font-mono text-[#444] bg-[#111] rounded border border-[var(--color-border)]">ESC</kbd>
      </div>
      <div class="cmd-list">
        <div class="px-3 py-2">
          <div class="text-[0.55rem] font-semibold tracking-[0.2em] text-[#333] uppercase mb-2 px-3">Navigation</div>
          {commands.map((cmd, i) => (
            <button class="cmd-item" data-index={i} onclick={`executeCmd(${i})`}>
              <span class="label">{cmd.name}</span>
              <span class="key">0{i + 1}</span>
            </button>
          ))}
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const cmds = [
    { name: 'Home', href: '#' },
    { name: 'Manifesto', href: '#manifesto' },
    { name: 'Focus', href: '#focus' },
    { name: 'Projects', href: '#projects' },
    { name: 'Tech Stack', href: '#stack' },
    { name: 'Writing', href: '/blog' },
    { name: 'GitHub', href: 'https://github.com/theyonecodes' },
  ];
  let idx = -1;

  (window as any).closePalette = () => {
    document.getElementById('palette')?.classList.remove('active');
    const inp = document.getElementById('palette-input') as HTMLInputElement;
    if (inp) inp.value = '';
    idx = -1;
  };

  (window as any).executeCmd = (i: number) => {
    if (i >= 0 && i < cmds.length) {
      const c = cmds[i];
      if (c.href.startsWith('http')) window.open(c.href, '_blank');
      else document.querySelector(c.href)?.scrollIntoView({ behavior: 'smooth' });
      (window as any).closePalette();
    }
  };

  document.addEventListener('keydown', (e) => {
    const pal = document.getElementById('palette');
    if (!pal?.classList.contains('active')) return;

    if (e.key === 'Escape') (window as any).closePalette();
    else if (e.key === 'ArrowDown') { e.preventDefault(); idx = Math.min(idx + 1, cmds.length - 1); updateSel(); }
    else if (e.key === 'ArrowUp') { e.preventDefault(); idx = Math.max(idx - 1, 0); updateSel(); }
    else if (e.key === 'Enter') { e.preventDefault(); (window as any).executeCmd(idx); }
    else if (e.key >= '1' && e.key <= '7') (window as any).executeCmd(parseInt(e.key) - 1);
  });

  function updateSel() {
    document.querySelectorAll('.cmd-item').forEach((el, i) => {
      el.classList.toggle('selected', i === idx);
    });
  }
</script>