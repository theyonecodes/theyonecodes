---
import { Icon } from 'astro-icon/components';
---

<section class="py-40 px-6 lg:px-12">
  <div class="max-w-4xl mx-auto text-center fade-up">
    <div class="flex items-center justify-center gap-2 mb-8">
      <span class="w-6 h-[1px] bg-[var(--color-accent)] opacity-50"></span>
      <span class="text-[0.6rem] font-semibold tracking-[0.3em] text-[var(--color-text-3)] uppercase">contact.init</span>
      <span class="w-6 h-[1px] bg-[var(--color-accent)] opacity-50"></span>
    </div>

    <h2 class="text-[clamp(3rem,10vw,6rem)] font-black tracking-tight mb-8">
      <span class="shimmer">Build Alone</span>
    </h2>

    <p class="text-sm text-[var(--color-text-3)] mb-16 leading-relaxed">
      I don't do collaborations.<br>
      <span class="text-[#666]">I build alone and ship.</span>
    </p>

    <a
      href="https://github.com/theyonecodes"
      target="_blank"
      rel="noopener"
      class="btn btn-primary neon-glow"
    >
      <Icon name="simple-icons:github" class="w-5 h-5" />
      <span>github.com/theyonecodes</span>
    </a>
  </div>
</section>