---
const techs = ['Python', 'Rust', 'TypeScript', 'Bash', 'Go', 'Linux', 'Git', 'Docker', 'WebGL', 'Astro']
---

<section id="stack" class="section-padding relative">
  <div class="section-container">
    <div class="max-w-3xl mb-16">
      <div class="reveal">
        <span class="section-label">Tech Stack</span>
      </div>
      <h2 class="section-title reveal delay-1">
        <span class="block">Tools & Languages</span>
      </h2>
    </div>

    <div class="flex flex-wrap gap-3">
      {techs.map((t, i) => (
        <span class={`tag reveal ${i < 10 ? 'delay-' + (i + 1) : ''}`}>{t}</span>
      ))}
    </div>
  </div>
</section>
