---
const stack = ['Python', 'JavaScript', 'Rust', 'Bash', 'Arch Linux', 'Docker', 'Electron', 'React', 'Flask'];
---

<section id="stack" class="section">
  <div class="max-w-7xl mx-auto">
    <div class="flex items-end justify-between mb-16 fade-up">
      <div>
        <span class="section-label">tech_stack.json</span>
        <h2 class="section-title">
          <span class="char-reveal">
            <span class="char gradient-text-cyan">T</span><span class="char gradient-text-cyan">e</span><span class="char gradient-text-cyan">c</span><span class="char gradient-text-cyan">h</span>
            <span class="char gradient-text-cyan"> </span>
            <span class="char gradient-text-cyan">S</span><span class="char gradient-text-cyan">t</span><span class="char gradient-text-cyan">a</span><span class="char gradient-text-cyan">c</span><span class="char gradient-text-cyan">k</span>
          </span>
        </h2>
      </div>
    </div>

    <div class="divider mb-16"></div>

    <div class="flex flex-wrap gap-2 fade-up">
      {stack.map((s, i) => (
        <span
          class="inline-flex text-[0.6rem] tracking-[0.15em] text-[#555] px-5 py-3 border border-[var(--color-border)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-all duration-300"
          style={{ transitionDelay: `${i * 0.05}s` }}
        >
          {s}
        </span>
      ))}
    </div>
  </div>
</section>