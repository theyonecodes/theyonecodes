<section id="stack" class="section-padding relative">
  <div class="section-container">
    <div class="max-w-3xl mb-16">
      <span class="section-label">Tech Stack</span>
      <h2 class="section-title">
        <span class="block">Tools & Languages</span>
      </h2>
    </div>

    <div class="flex flex-wrap gap-2">
      {['Python', 'Rust', 'TypeScript', 'Bash', 'Go', 'Linux', 'Git', 'Docker', 'WebGL', 'Astro'].map(t => (
        <span class="tag stack-tag">{t}</span>
      ))}
    </div>
  </div>
</section>

<script>
import gsap from 'gsap'
import { ScrollTrigger } from 'gsap/ScrollTrigger'

gsap.registerPlugin(ScrollTrigger)

gsap.fromTo('.stack-tag', {
  opacity: 0,
  scale: 0.8,
}, {
  opacity: 1,
  scale: 1,
  duration: 0.4,
  stagger: 0.04,
  ease: 'back.out(1.7)',
  scrollTrigger: {
    trigger: '#stack',
    start: 'top 85%',
    toggleActions: 'play none none reverse',
  },
})
</script>
