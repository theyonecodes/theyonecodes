<script>
  // Noise overlay
  const noiseCanvas = document.getElementById('noise-canvas') as HTMLCanvasElement
  const noiseCtx = noiseCanvas?.getContext('2d')
  
  if (noiseCanvas && noiseCtx) {
    const resize = () => {
      noiseCanvas.width = window.innerWidth * window.devicePixelRatio
      noiseCanvas.height = window.innerHeight * window.devicePixelRatio
      noiseCanvas.style.width = window.innerWidth + 'px'
      noiseCanvas.style.height = window.innerHeight + 'px'
      noiseCtx?.scale(window.devicePixelRatio, window.devicePixelRatio)
    }
    resize()
    window.addEventListener('resize', resize)

    function drawNoise() {
      if (!noiseCtx) return
      const w = noiseCanvas.width
      const h = noiseCanvas.height
      const idata = noiseCtx.createImageData(w, h)
      const buffer32 = new Uint32Array(idata.data.buffer)
      const len = buffer32.length

      for (let i = 0; i < len; i++) {
        if (Math.random() < 0.5) {
          buffer32[i] = 0xff000000
        }
      }
      
      noiseCtx.putImageData(idata, 0, 0)
      requestAnimationFrame(drawNoise)
    }
    
    drawNoise()
  }
</script>