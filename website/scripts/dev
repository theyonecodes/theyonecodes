#!/usr/bin/env bash
set -e

cd "$(dirname "$0")/.."

echo "[dev] Starting Astro..."

# Start server
npx astro dev --host 0.0.0.0 --port 4321 &
ASTRO_PID=$!

# Wait for server
for i in $(seq 1 30); do
  if curl -s http://localhost:4321 >/dev/null 2>&1; then
    break
  fi
  sleep 0.5
done

URL="http://localhost:4321"
echo "[dev] $URL"

# Launch Chrome (detached)
/opt/google/chrome/chrome "$URL" &>/dev/null &
disown

echo "[dev] Press Ctrl+C to stop"
trap "kill $ASTRO_PID 2>/dev/null" EXIT
wait $ASTRO_PID